# === YouTube каналы для поиска видео (через запятую) ===
YOUTUBE_CHANNELS=https://www.youtube.com/@upvotemedia,https://www.youtube.com/@tuchniyzhab

# === Тема/идея для поиска контента (AI обновляет каждые N видео) ===
CONTENT_TOPIC=Комплексы парней

# === Настройки видео ===
# Длительность каждого клипа в секундах
CLIP_DURATION=60
# Сколько клипов нарезать с одного YouTube-видео
CLIPS_PER_VIDEO=3
# Сколько YouTube-видео обрабатывать за один суточный цикл (CLIPS_PER_VIDEO * VIDEOS_PER_CYCLE = клипов в день)
VIDEOS_PER_CYCLE=2
# Задержка между отправками клипов в Telegram (секунды)
DELAY_BETWEEN_SENDS=3
# Язык субтитров
SUBTITLE_LANGUAGE=ru

# === Пути ===
# Папка для скачанных файлов (сырьё + логи)
DOWNLOAD_DIR=logs
# Папка для готовых видео
OUTPUT_DIR=output
# Папка с категориями фоновых видео (каждый .txt = категория)
BACKGROUNDS_DIR=backgrounds

